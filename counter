import { useState } from "react";

function App() {
  const [count, setCount] = useState(90);

  return (
    <div>
      <h1>{count}</h1>

      <button onClick={() => { {setCount(count - 1);}}}>-</button>
      <button onClick={() => {if (count < 100) {setCount(count + 1);}}}>+</button>
    </div>
  );
}

export default App;




